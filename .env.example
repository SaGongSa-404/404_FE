# 로컬 백엔드 (redirect: http://localhost:8080/login/oauth2/code/{provider})
API_BASE_URL=http://localhost:8080

# 카카오 네이티브 앱 키 (Android). KAKAO_CLIENT_ID(OAuth)와 다름 — 없으면 비움
KAKAO_NATIVE_APP_KEY=

# POST /api/dev/users/test 응답 userId 붙여넣기
DEV_USER_ID=

# API만 먼저: x_user_id | OAuth 후: bearer
DEV_AUTH_MODE=x_user_id